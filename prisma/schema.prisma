// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Plan tier: free | monthly | yearly | lifetime
  plan                   String    @default("free")

  // Stripe subscription
  stripeCustomerId         String?   @unique
  stripeSubscriptionId     String?   @unique
  stripePriceId            String?
  stripeCurrentPeriodEnd   DateTime?
  stripeSubscriptionStatus String?   // trialing | active | past_due | canceled

  accounts   Account[]
  sessions   Session[]
  songs      Song[]
  categories Category[]
  activities ActivityLog[]
}

// Generic activity log — one row per notable event (account_created, login,
// sub_started, song_created, ...). meta holds event context (songId, title,
// plan, source). userId is nullable so logs survive user deletion.
model ActivityLog {
  id        String   @id @default(cuid())
  userId    String?
  type      String
  meta      Json?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([userId, createdAt])
  @@index([type, createdAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Song {
  id        String   @id @default(cuid())
  userId    String
  title     String
  artist    String?
  key       String?
  capo      Int?
  tempo     Int?
  content   Json     // Structured chord sheet data (sections, lines, chords)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  categories SongCategory[]

  @@index([userId])
}

model Category {
  id        String   @id @default(cuid())
  userId    String
  name      String
  order     Int      @default(0)
  parentId  String?
  createdAt DateTime @default(now())

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  songs    SongCategory[]
  parent   Category?      @relation("Subcategories", fields: [parentId], references: [id], onDelete: Cascade)
  children Category[]     @relation("Subcategories")

  @@index([userId])
}

model SongCategory {
  songId     String
  categoryId String
  order      Int    @default(0)

  song     Song     @relation(fields: [songId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([songId, categoryId])
}

model Share {
  id        String   @id @default(cuid())
  title     String
  artist    String   @default("")
  content   Json     // { lines, style } — style includes backgroundImage
  createdAt DateTime @default(now())
}
