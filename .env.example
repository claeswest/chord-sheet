# Database
DATABASE_URL="postgresql://user:password@localhost:5432/chordsheetmaker?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# OAuth Providers
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Sign in with Apple (optional — button hidden until both are set).
# APPLE_CLIENT_SECRET is the JWT from scripts/generate-apple-secret.mjs (renew <=6mo).
APPLE_CLIENT_ID=""
APPLE_CLIENT_SECRET=""

# Passwordless magic-link email via Resend (optional — field hidden until set).
# EMAIL_FROM must use a Resend-verified domain in production, e.g.
# "ChordSheetMaker <noreply@chordsheetmaker.ai>". Defaults to onboarding@resend.dev,
# which only delivers to the Resend account owner's own inbox (testing only).
RESEND_API_KEY=""
EMAIL_FROM=""

# Anthropic (AI features)
ANTHROPIC_API_KEY=""

# Stripe (payments)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_PRO_PRICE_ID=""
